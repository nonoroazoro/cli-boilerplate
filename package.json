{
    "name": "cli-boilerplate",
    "version": "1.0.0",
    "type": "module",
    "engines": {
        "node": ">=21.0.0"
    },
    "bin": {
        "cli": "./src/cli.ts"
    },
    "scripts": {
        "prepare": "lefthook install",
        "clean": "rimraf dist",
        "dev": "bun run src/cli.ts",
        "prebuild": "bun run test && bun run clean",
        "prebuild-all": "bun run test && bun run clean",
        "build": "bun run scripts/build.ts",
        "build-all": "bun run scripts/build.ts --all",
        "postbuild": "rimraf --glob '.*.bun-build'",
        "postbuild-all": "rimraf --glob '.*.bun-build'",
        "test": "bun test",
        "lint": "eslint --fix .",
        "format": "dprint fmt",
        "upgradepackages": "ncu -u -x eslint"
    },
    "dependencies": {
        "citty": "^0.2.1",
        "ink": "^6.8.0",
        "react": "^19.2.4",
        "tinyrainbow": "^3.1.0"
    },
    "devDependencies": {
        "@types/bun": "^1.3.11",
        "@types/react": "^19.2.14",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "dprint": "^0.53.1",
        "eslint": "^9.34.0",
        "eslint-config-zoro": "^9.1.3",
        "eslint-plugin-n": "^17.24.0",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "ink-testing-library": "^4.0.0",
        "lefthook": "^2.1.4",
        "npm-check-updates": "^20.0.0",
        "react-devtools-core": "^7.0.1",
        "rimraf": "^6.1.3"
    }
}
